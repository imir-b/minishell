ifndef VERBOSE
.SILENT:
endif

SHELL			=	/bin/bash

# ------------------------------------------------------------------------------
# exe
# ------------------------------------------------------------------------------

NAME			=	minishell

# ------------------------------------------------------------------------------
# dir
# ------------------------------------------------------------------------------

SRC_DIR			=	src
OBJ_DIR			=	obj
INC_DIR			=	inc

SUB_DIRS		=	data \
					parsing \
					parsing/ast \
					parsing/expand \
					parsing/heredoc \
					exec \
					exec/built-in \
					utils \
					utils/io \
					utils/string \
					utils/memory \
					utils/gnl \
					utils/list \
					utils/conversions \
					signals

# ------------------------------------------------------------------------------
# files
# ------------------------------------------------------------------------------

SRC				=	$(filter-out $(SRC_DIR)/grammar.c, $(wildcard $(SRC_DIR)/*.c)) \
					$(foreach dir, $(SUB_DIRS), $(wildcard $(SRC_DIR)/$(dir)/*.c))

OBJ				=	$(patsubst $(SRC_DIR)/%.c, $(OBJ_DIR)/%.o, $(SRC))

# ------------------------------------------------------------------------------
# flags
# ------------------------------------------------------------------------------

MAKEFLAGS 		+=	--no-print-directory

CFLAGS			=	-Wall -Wextra -Werror

CPPFLAGS		=	-I $(INC_DIR)

INCLUDE_LIB		=	-lreadline

# ------------------------------------------------------------------------------
# colors
# ------------------------------------------------------------------------------

RED				=	\033[31;1m
BLU				=	\033[34;1m
CYAN			=	\033[36;1m
PUR				=	\033[35;1m
END				=	\033[0m

# ------------------------------------------------------------------------------
# rules
# ------------------------------------------------------------------------------

all:			$(NAME)

$(OBJ_DIR)/%.o:	$(SRC_DIR)/%.c $(wildcard $(INC_DIR)/*.h)
				@mkdir -p $(dir $@)
				@$(CC) $(CFLAGS) $(CPPFLAGS) -c $< -o $@

$(NAME):		$(OBJ)
	@$(CC) -g $(OBJ) $(INCLUDE_LIB) $(CFLAGS) $(CPPFLAGS) -o $(NAME)
